<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="202606020730-001" author="jcarvaja">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="org_utilization_preference" columnName="last_updated"/>
    </preConditions>

    <comment>Align org_utilization_preference with ModificationTrackedEntity last_modified column</comment>
    <renameColumn tableName="org_utilization_preference"
                  oldColumnName="last_updated"
                  newColumnName="last_modified"/>

    <rollback>
      <renameColumn tableName="org_utilization_preference"
                    oldColumnName="last_modified"
                    newColumnName="last_updated"/>
    </rollback>
  </changeSet>

</databaseChangeLog>
